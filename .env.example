# Database (Railway managed PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/TaskMeAgents
DATABASE_SCHEMA=taskme_agents

# Temporal (self-hosted on Railway)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=taskme-agents

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Attachments (Railway persistent volume)
ATTACHMENT_BASE_PATH=/data/attachments
MAX_ATTACHMENT_SIZE_MB=50

# MCP
MCP_IDLE_TIMEOUT_MINUTES=10
MCP_MAX_SERVERS=500

# Auth (seed admin API key on first startup)
ADMIN_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["https://taskme-app.com"]
